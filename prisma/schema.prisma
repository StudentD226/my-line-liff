generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL") 
}
model User {
  id          Int      @id @default(autoincrement())
  lineId      String   @unique
  fullName    String
  houseNumber String
  phone       String
  createdAt   DateTime @default(now())
}